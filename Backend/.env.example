# ─────────────────────────────────────────────────────────────
#  Sevankur Backend — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  NEVER commit the .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── Server ─────────────────────────────────────────────────────
# The TCP port the Express server listens on.
PORT=5000

# Application environment. Accepted values: development | production | test
NODE_ENV=development

# ── MongoDB ────────────────────────────────────────────────────
# Full MongoDB connection string (Atlas or local).
# Examples:
#   Atlas:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/sevankur?retryWrites=true&w=majority
#   Local:  mongodb://localhost:27017/sevankur
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster.mongodb.net/sevankur?retryWrites=true&w=majority

# ── JWT Authentication ──────────────────────────────────────────
# Long, random string used to sign JSON Web Tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# REQUIRED — the server will refuse to start without this.
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS

# JWT token lifetime (ms-compatible string).  e.g. 7d | 24h | 3600000
JWT_EXPIRES_IN=7d

# ── xAI / Grok API ─────────────────────────────────────────────
# Your xAI API key. Obtain one at https://console.x.ai/
# REQUIRED — AI endpoints will return fallback responses without it.
GROK_API_KEY=xai-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Grok model identifier to use for completions.
GROK_MODEL=grok-1

# Maximum time (ms) to wait for a Grok API response before timing out.
GROK_TIMEOUT_MS=10000

# How many times to retry a failed Grok request before giving up.
GROK_MAX_RETRIES=2

# ── AI Behaviour ───────────────────────────────────────────────
# Sampling temperature for Grok responses (0.0 = deterministic, 1.0 = creative).
AI_TEMPERATURE=0.7

# Maximum number of chat-history messages sent as context to Grok.
AI_CONTEXT_WINDOW=10

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In development you can use * but restrict this in production.
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ── File Uploads (Multer) ──────────────────────────────────────
# Absolute or relative path where uploaded documents are saved.
UPLOAD_DIR=./uploads

# Maximum single-file size in bytes (default 10 MB).
MAX_FILE_SIZE=10485760

# ── Logging ────────────────────────────────────────────────────
# Minimum log level written to file.
# Accepted values: error | warn | info | verbose | debug | silly
LOG_LEVEL=info

# Directory where Winston log files are written.
LOG_DIR=./logs

# ── Rate Limiting (optional) ───────────────────────────────────
# Requests allowed per IP per window.
RATE_LIMIT_MAX=100

# Window length in milliseconds (default 15 minutes).
RATE_LIMIT_WINDOW_MS=900000

# ─────────────────────────────────────────────────────────────
#  VALIDATION RULES
# ─────────────────────────────────────────────────────────────
#  The following variables are REQUIRED for the server to start:
#    • MONGODB_URI   — database connection
#    • JWT_SECRET    — minimum 32 characters
#    • GROK_API_KEY  — must start with "xai-"
#
#  To verify your .env before starting:
#    node scripts/validateEnv.js
# ─────────────────────────────────────────────────────────────
